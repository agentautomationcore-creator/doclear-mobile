    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "app.doclear.mobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image",
      "expo-sharing",
      "expo-localization",
      "expo-web-browser",
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "DocLear needs camera access to scan documents"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "DocLear needs photo library access to upload documents"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1E293B"
        }
      ],
      "expo-apple-authentication",
      "expo-font",
      "@sentry/react-native"
    ],
