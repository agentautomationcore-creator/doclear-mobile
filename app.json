{
  "expo": {
    "name": "DocLear",
    "slug": "doclear-expo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "doclear",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.doclear.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "DocLear needs camera access to scan documents",
        "NSPhotoLibraryUsageDescription": "DocLear needs photo library access to upload documents",
        "NSMicrophoneUsageDescription": "Microphone access is not used by DocLear but is required by the camera framework",
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
